# Скопируйте в .env и при необходимости поменяйте значения.

# SQLite для локального теста. Для продакшена: postgresql://...
DATABASE_URL="file:./dev.db"

PORT=3000
HOST=0.0.0.0

# Токен бота от @BotFather.
# Если не задан — backend работает в DEV-режиме (вход по заголовку X-Dev-Id),
# уведомления о мэтчах не отправляются. Удобно тестировать в браузере.
# BOT_TOKEN=123456:ABC-DEF...
