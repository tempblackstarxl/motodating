{
  "name": "motodating",
  "version": "0.1.0",
  "private": true,
  "description": "MotoDating — Telegram Mini App для знакомств девушек и мужчин на мотоциклетную тематику (MVP)",
  "workspaces": [
    "backend",
    "frontend",
    "bot"
  ],
  "scripts": {
    "setup": "npm install && npm run db:setup --workspace backend",
    "dev": "concurrently -n backend,frontend -c green,cyan \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:bot": "npm run dev --workspace bot"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
